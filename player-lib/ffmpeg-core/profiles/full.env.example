# EXAMPLE opt-in profile: a bigger core that additionally decodes the still-patented lossless
# formats the default omits — MLP (and you can add DTS-HD/MA extensions). The default
# `free-audio` core already decodes AAC-LC, AC-3, E-AC-3 and DTS core. NOT built by default.
#
# ⚠️  PATENT / LICENSING RESPONSIBILITY IS YOURS. MLP and other newer codecs are covered by
# active patents in many jurisdictions; distributing or operating a build that decodes them may
# require licenses. Only build/use this if you understand and accept those obligations.
#
# To use:  cp full.env.example full.env  (edit as desired), then  FFMPEG_PROFILE=full npm run build:ffmpeg
#
# The codecs below are ffmpeg's NATIVE decoders — they need no external lib and no --enable-gpl,
# so the core stays LGPL; the concern is purely PATENTS, not copyleft. (Adding GPL/patent VIDEO
# encoders such as libx264/libx265 would additionally require --enable-gpl AND re-adding their
# builder stages + link libs in the Dockerfile — video encoding is out of scope for this player.)
FFMPEG_CONF="--disable-everything \
--enable-libopus --enable-libvorbis --enable-zlib \
--enable-decoder=libvorbis,vorbis,libopus,opus,flac,alac,wavpack,tta,aac,pcm_s16le,pcm_s16be,pcm_s24le,pcm_s24be,pcm_s32le,pcm_f32le,pcm_u8,ac3,eac3,dca,truehd,mlp \
--enable-encoder=libopus,aac,flac \
--enable-demuxer=matroska \
--enable-muxer=mp4,mov \
--enable-parser=opus,vorbis,flac,aac,ac3,dca \
--enable-filter=aresample,aformat,anull \
--enable-protocol=file"

FFMPEG_LINK_LIBS="-lopus -lvorbis -lvorbisenc -lvorbisfile -logg -lz"
