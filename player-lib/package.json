{
  "name": "@matroska-js/player",
  "version": "0.1.0",
  "license": "AGPL-3.0-only",
  "type": "module",
  "description": "Reusable browser MKV player UI: WASM MKV→fMP4 remux + MSE + video.js v10, with configurable controls and a pluggable ffmpeg.wasm build.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/davidprojekt/matroska.js.git",
    "directory": "player-lib"
  },
  "homepage": "https://github.com/davidprojekt/matroska.js#readme",
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": "./src/index.js",
    "./style.css": "./src/style.css"
  },
  "files": [
    "src",
    "scripts",
    "ffmpeg-core",
    "README.md"
  ],
  "scripts": {
    "build:ffmpeg": "bash ffmpeg-core/build.sh",
    "setup-ffmpeg": "node scripts/setup-ffmpeg-core.mjs",
    "test": "node --test src/mse.test.js src/subtitles.test.js"
  },
  "dependencies": {
    "@videojs/html": "^10.0.0-beta.24",
    "@matroska-js/remux": "^0.1.0",
    "jassub": "^2.5.6",
    "libpgs": "^0.8.1"
  },
  "optionalDependencies": {
    "@ffmpeg/ffmpeg": "^0.12.10",
    "@ffmpeg/util": "^0.12.1"
  }
}
