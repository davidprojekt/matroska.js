{
  "name": "mkvplayer-nextcloud",
  "private": true,
  "version": "0.1.0",
  "license": "AGPL-3.0-only",
  "type": "module",
  "description": "Nextcloud app that plays .mkv/.mka files in the Viewer via mkv-player-ui.",
  "scripts": {
    "dev": "vite --mode development build --watch",
    "clean": "rm -rf js css dist assets",
    "build": "npm run clean && bash -c 'cd ../mkv-player && npm run build' && vite build",
    "build:app": "npm run clean && vite build",
    "setup:ffmpeg": "FFMPEG_OUT_DIR=ffmpeg node ../player-lib/scripts/setup-ffmpeg-core.mjs",
    "assemble": "bash scripts/assemble.sh",
    "deploy": "npm run build:app && npm run setup:ffmpeg && npm run assemble"
  },
  "dependencies": {
    "mkv-player-ui": "file:../player-lib"
  },
  "devDependencies": {
    "@nextcloud/initial-state": "^3.0.0",
    "@nextcloud/router": "^3.1.0",
    "@nextcloud/vite-config": "^2.5.4",
    "playwright-core": "^1.61.1",
    "vite": "^7.3.6",
    "vue": "^3.5.39"
  }
}
