{
  "name": "matroska-player-web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Browser MKV player: WASM MKV→fMP4 remux + MSE + video.js v10",
  "scripts": {
    "copy-sw": "node -e \"require('fs').copyFileSync('node_modules/webtorrent/dist/sw.min.js','public/sw.min.js')\"",
