    "prebuild": "npm run copy-sw",
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "@videojs/html": "^10.0.0-beta.24",
    "ebml-wasm": "file:../ebml-wasm/pkg",
    "webtorrent": "^3.0.16"
  },
  "devDependencies": {
    "vite": "^6.0.0"
  }
}
